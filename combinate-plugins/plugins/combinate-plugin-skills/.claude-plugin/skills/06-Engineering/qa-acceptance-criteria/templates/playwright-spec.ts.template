import { test, expect, Page } from '@playwright/test'

async function go(page: Page, path: string) {
  const response = await page.goto(path, { waitUntil: 'networkidle', timeout: 30000 })
  await page.waitForLoadState('domcontentloaded')
  return response
}

// ---------------------------------------------------------------------------
// Per-page sections (one describe per section in the doc)
// ---------------------------------------------------------------------------

test.describe('{Section name from doc}', () => {
  test('{criterion or grouped criteria, plain English}', async ({ page }) => {
    await go(page, '{path}')
    await expect(page.locator('h1', { hasText: '{Heading text}' })).toBeVisible()
    // ...one assertion per criterion
  })
})

// ---------------------------------------------------------------------------
// Cross-cutting: Navigation
// ---------------------------------------------------------------------------

test.describe('Navigation', () => {
  test('menu opens and all nav links navigate', async ({ page }) => {
    await go(page, '/')
    await page.click('{menu toggle selector}')
    const menu = page.locator('{menu panel selector}')
    await expect(menu).toBeVisible()

    const expected: Record<string, string> = {
      HOME: '/',
      // ...project nav items
    }
    for (const [label, href] of Object.entries(expected)) {
      const link = page.getByRole('link', { name: label, exact: true }).first()
      await expect(link).toHaveAttribute('href', href)
    }
  })

  test('logo link returns home', async ({ page }) => {
    await go(page, '{any non-home path}')
    const logo = page.getByRole('link', { name: '{logo accessible name}' }).first()
    await expect(logo).toHaveAttribute('href', '/')
  })
})

// ---------------------------------------------------------------------------
// Cross-cutting: Responsive
// ---------------------------------------------------------------------------

test.describe('Responsive - mobile', () => {
  test.use({ viewport: { width: 390, height: 844 } })

  test('{page} stacks correctly at mobile width', async ({ page }) => {
    await go(page, '{path}')
    const container = page.locator('{layout container selector}').first()
    const direction = await container.evaluate(
      (el) => getComputedStyle(el as HTMLElement).flexDirection
    )
    expect(direction).toBe('column')
  })
})

// ---------------------------------------------------------------------------
// Cross-cutting: Metadata / SEO
// ---------------------------------------------------------------------------

test.describe('Metadata / SEO', () => {
  const pages = [
    { path: '/', title: /^{Project}$/ },
    { path: '/about-us', title: /About Us \| {Project}/ },
    // ...one entry per critical-path route
  ]

  for (const p of pages) {
    test(`${p.path} has title + og tags`, async ({ page }) => {
      await go(page, p.path)
      await expect(page).toHaveTitle(p.title)
      const og = (prop: string) =>
        page.locator(`meta[property="og:${prop}"]`).getAttribute('content')
      expect(await og('title')).toBeTruthy()
      expect(await og('type')).toBe('website')
      expect(await og('site_name')).toBe('{Project}')
      expect(await og('image')).toBeTruthy()
      const canonical = await page.locator('link[rel="canonical"]').getAttribute('href')
      expect(canonical).toMatch(/^https?:\/\//)
    })
  }
})

// ---------------------------------------------------------------------------
// Cross-cutting: Console / Network health
// ---------------------------------------------------------------------------

test.describe('Console health', () => {
  const criticalPages = [
    '/',
    // ...project critical-path routes
  ]

  for (const path of criticalPages) {
    test(`no console errors on ${path}`, async ({ page }) => {
      const errors: string[] = []
      page.on('pageerror', (e) => errors.push(e.message))
      page.on('console', (m) => {
        if (m.type() === 'error') errors.push(m.text())
      })
      await go(page, path)
      expect(errors, `Console errors on ${path}: ${errors.join('; ')}`).toEqual([])
    })
  }
})

